# Datalyze AI - Environment Variables Reference Blueprint
# Copy this file to backend/.env and replace placeholders with secure production configurations.

# Database url configuration: supports sqlite (sqlite:///./datalyze.db) or postgreSQL (postgresql+asyncpg://...)
DATABASE_URL="sqlite:///./datalyze.db"

# Secret key used for signing JWT access tokens (use a cryptographically secure random string in production)
SECRET_KEY="PRODUCTION_REPLACE_WITH_A_SECURE_RANDOM_HASH_STRING"

# Encryption algorithm for JWT signatures
ALGORITHM="HS256"

# Token expiration duration limit
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS origins policy: comma-separated list of allowed frontend domains
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Optional Cloud API keys (e.g. Groq Cloud Engine)
GROQ_API_KEY="PASTE_YOUR_GROQ_KEY_HERE"
